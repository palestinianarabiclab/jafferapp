{
    "buildCommand": "node scripts/generate-runtime-config.js",
    "outputDirectory": ".",
    "rewrites": [
        {
            "source": "/((?!assets/|js/|styles.css|favicon.ico).*)",
            "destination": "/index.html"
        }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                },
                {
                    "key": "Referrer-Policy",
                    "value": "strict-origin-when-cross-origin"
                }
            ]
        }
    ]
}
